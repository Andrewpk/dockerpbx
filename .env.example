# Pin to a COMMIT SHA from the branch you want, not a branch name.
# You asked for the freepbx-arm64-raspberry branch -- resolve it to a SHA:
#
#   git ls-remote https://github.com/slythel2/freepbx-arm64-install freepbx-arm64-raspberry
#
# A branch name here means `docker build --no-cache` can silently pull different
# code tomorrow than it did today.
#
# Honesty note: the SHA pins install.sh ONLY. The script itself then fetches
# its helper files from the branch tip and the Asterisk tarball from the
# repo's *latest* GitHub release (sha256-verified, but not pinned). See README.
INSTALLER_REF=

# Pinned so image rebuilds stay compatible with the existing mysql volume.
# Generate once and never change it:  openssl rand -base64 24 | tr -d '/+='
FREEPBX_DB_PASS=

# FreePBX admin UI port. Host networking = this must not collide with your
# other container.
APACHE_PORT=8080

PBX_HOSTNAME=pbx.home.arpa
TZ=Atlantic/Reykjavik
